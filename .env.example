NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# Used by the /api/keepalive cron to prevent Supabase from auto-pausing the project.
# Generate any random string; Vercel injects it as the Bearer token on cron requests.
CRON_SECRET=generate-a-random-string
